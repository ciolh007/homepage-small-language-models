---
interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/homepage-small-language-models/favicon.svg" />
		<link rel="icon" href="/homepage-small-language-models/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		padding: 0;
		margin: 0;
		width: 100%;
		height: 100%;
		color: #E0F7FA
	}
</style>
